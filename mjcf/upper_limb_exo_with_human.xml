<mujoco model="upper_limb_exo_with_human">
    <!--
      통합 파일: new_upper_limb_exo.xml (로봇) + scene_with_human.xml (시각용 사람/의자)
      를 하나로 합친 self-contained MJCF. <include> 없이 단독 실행 가능.

      ● 물리 무영향: 모든 사람/의자 geom 은 contype=0 conaffinity=0 (충돌 X), density=0 (질량 X).
        body 에 joint 없음 → world 에 고정된 장식. (COM 계산용 명목 inertial 만 부여; world 고정이라
        그 질량은 로봇 dynamics 에 들어가지 않음.)
      ● 정렬: 사람의 *오른쪽 어깨* = 로봇 어깨(link1, world (0,0,0.7)).
      ● 비율: 인체측정 통계 (Drillis & Contini / Winter, stature H≈1.60 m 성인) 기반 분절 길이.
      ● 로봇 가시성: 사람을 왼쪽으로 +0.12 m (body pos y) 이동해 로봇을 몸통 부피 밖으로 빼냄.

      메쉬 의존성: asset 의 STL 은 meshdir="meshes/" 기준 상대경로 (new_design/*.stl).
    -->

    <option gravity="0 0 -9.81" />
    <compiler angle="degree" meshdir="meshes/" autolimits="true" />
    <option timestep="0.001"></option>     <!-- time step for simulations  -->

    <default>
        <geom type="mesh" />

        <default class="visual">
            <geom contype="0" conaffinity="0" group="0" density="0" rgba="0.5 0.5 0.5 1" />
        </default>
        <default class="transparent">
            <geom contype="0" conaffinity="0" group="0" density="0" rgba="0.5 0.5 0.5 0.3" />
        </default>

        <!-- armature 값: "AK109": 0.00812, "AK7010": 0.00414, "AK606": 0.00088. damping/frictionloss 는 0. -->
        <default class="AK109_actuator">
            <joint damping="0" armature="0" frictionloss="0" />
        </default>
        <default class="AK7010_actuator">
            <joint damping="0" armature="0" frictionloss="0" />
        </default>
        <default class="AK606_actuator">
            <joint damping="0" armature="0" frictionloss="0" />
        </default>

        <!-- 사람/의자 장식용: 물리 무영향 -->
        <default class="deco">
            <geom contype="0" conaffinity="0" group="2" density="0"/>
        </default>
    </default>

    <!--   Fusion outputs meshes with mm units by default, but must be converted to m in MuJoCo, hence
    the scaling   -->
    <asset>
        <mesh name="link0" file="new_design/link0.stl" scale="0.001 0.001 0.001" />
        <mesh name="link1" file="new_design/link1.stl" scale="0.001 0.001 0.001" />
        <mesh name="link2" file="new_design/link2.stl" scale="0.001 0.001 0.001" />
        <mesh name="link3" file="new_design/link3.stl" scale="0.001 0.001 0.001" />
        <mesh name="dummy_upper_arm" file="new_design/dummy_upper_arm.stl" scale="0.001 0.001 0.001" />
        <mesh name="dummy_lower_arm" file="new_design/dummy_lower_arm.stl" scale="0.001 0.001 0.001" />

        <texture builtin="flat" height="100" rgb1="1 1 1" rgb2="1 1 1" type="skybox" width="100" />
        <texture name="texplane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" width="100" height="100" />
        <material name="MatPlane" reflectance="0.1" texture="texplane" texrepeat="1 1" texuniform="true" />

        <!-- 사람/의자 재질 -->
        <material name="skin"  rgba="0.80 0.61 0.46 1"/>
        <material name="shirt" rgba="0.24 0.44 0.72 1"/>
        <material name="pants" rgba="0.22 0.24 0.31 1"/>
        <material name="shoe"  rgba="0.11 0.11 0.13 1"/>
        <material name="hair"  rgba="0.16 0.10 0.06 1"/>
        <material name="eyewhite" rgba="0.95 0.95 0.95 1"/>
        <material name="eyedark"  rgba="0.08 0.08 0.10 1"/>
        <material name="mouth"    rgba="0.62 0.30 0.30 1"/>
        <material name="wood"  rgba="0.52 0.36 0.20 1"/>
        <material name="wood2" rgba="0.40 0.27 0.15 1"/>
    </asset>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
        <rgba haze="1 1 1 1" /> <global azimuth="-90" elevation="-90" />
    </visual>

    <worldbody>
        <!-- ground 평면 z=-0.25: 고정 베이스 팔은 바닥에 닿지 않으므로 동역학/제어/최적화 무관.
             좌식 성인(어깨 world 0.7 m)이 바닥에 자연스럽게 앉도록 시각용으로 내림. -->
        <geom name="ground" pos="0 0 -0.25" size="5 5 0.05" type="plane" material="MatPlane"
            friction="1 1 0.1" condim="3" conaffinity="1" contype="1" group="2" rgba="1 1 1 1" />

        <light cutoff="1000" diffuse="1 1 1" dir="-0 0 -1.3" directional="true" exponent="1"
            pos="0 0 1.3" specular=".1 .1 .1" castshadow="false" />

        <!-- Coordinate axes -->
        <geom type="capsule" fromto="0 0 0 0.1 0 0" size="0.005" rgba="1 0 0 1"  contype="0" conaffinity="0"/>
        <geom type="capsule" fromto="0 0 0 0 0.1 0" size="0.005" rgba="0 1 0 1"  contype="0" conaffinity="0"/>
        <geom type="capsule" fromto="0 0 0 0 0 0.1" size="0.005" rgba="0 0 1 1"  contype="0" conaffinity="0"/>

        <!--   link0 -->
        <body name="link0" pos="0 0 0.7" euler="-90 0 0">
            <geom type="mesh" class="visual" mesh="link0" rgba="0.75 0.75 0.75 1"/>
            <inertial pos="-0.013E-03 0.011E-03 -29.442E-03"
                        mass="2797.101E-03"
                        fullinertia="2.158E-03 2.155E-03 3.143E-03 2134.574E-09 -791.755E-09 633.36E-09" />
                    <!-- Coordinate axes -->
            <geom type="capsule" fromto="0 0 0 0.1 0 0" size="0.005" rgba="1 0 0 1"  contype="0" conaffinity="0"/>
            <geom type="capsule" fromto="0 0 0 0 0.1 0" size="0.005" rgba="0 1 0 1"  contype="0" conaffinity="0"/>
            <geom type="capsule" fromto="0 0 0 0 0 0.1" size="0.005" rgba="0 0 1 1"  contype="0" conaffinity="0"/>

            <!--   link1 -->
            <body name="link1" pos="0 0 0" euler="0 0 0">
                <geom type="mesh" class="visual" mesh="link1" rgba="0.95 0.75 0.55 1"/>
                <inertial pos="0.01E-03 90.609E-03 -1.503E-03"
                            mass="1518.31E-03"
                            fullinertia="1.365E-03 8.234E-04 1.636E-03 -354.196E-09 681.552E-09 62766.752E-09" />

                <!-- range : physical limit -->
                <joint type="hinge" name="shoulder_pitch" axis="0 0 1" pos="0 0 0" range="-120 0"
                    class="AK109_actuator" />
                        <!-- Coordinate axes -->
                <geom type="capsule" fromto="0 0 0 0.1 0 0" size="0.005" rgba="1 0 0 1"  contype="0" conaffinity="0"/>
                <geom type="capsule" fromto="0 0 0 0 0.1 0" size="0.005" rgba="0 1 0 1"  contype="0" conaffinity="0"/>
                <geom type="capsule" fromto="0 0 0 0 0 0.1" size="0.005" rgba="0 0 1 1"  contype="0" conaffinity="0"/>

                            <!--   link2 -->
                <body name="link2" pos="0 72.73E-03 100E-03" euler="90 0 0">
                    <geom type="mesh" class="visual" mesh="link2" rgba="0.6 0.85 0.7 1"/>
                    <inertial pos="-3.593E-3 -76.373E-3 -155.796E-3"
                                mass="2718.741E-3"
                                fullinertia="1.741E-02 1.798E-02 3.978E-03 6.799E-04 1.131E-03 -3.609E-03" />
                    <joint type="hinge" name="shoulder_yaw" axis="0 0 1" pos="0 0 0" range="-5 90"
                        class="AK606_actuator" />
                            <!-- Coordinate axes -->
                    <geom type="capsule" fromto="0 0 0 0.1 0 0" size="0.003" rgba="1 0 0 1"  contype="0" conaffinity="0"/>
                    <geom type="capsule" fromto="0 0 0 0 0.1 0" size="0.003" rgba="0 1 0 1"  contype="0" conaffinity="0"/>
                    <geom type="capsule" fromto="0 0 0 0 0 0.1" size="0.003" rgba="0 0 1 1"  contype="0" conaffinity="0"/>

                            <!--   link3 -->
                    <body name="link3" pos="-1.125E-09 -64.944E-03 -196.15E-03" euler="-90 0 0">
                        <geom type="mesh" class="visual" mesh="link3" rgba="0.7 0.7 0.9 1"/>
                        <inertial pos="-5.289E-08 121.422E-03 -1.713E-03"
                                    mass="235.178E-03"
                                    fullinertia="7.489E-04 61324.892E-09 7.968E-04 0.518E-09 -0.094E-09 3826.504E-09" />

                        <!-- elbow range +90deg is not realistic ??-->
                        <joint type="hinge" name="elbow" axis="0 0 1" pos="0 0 0" range="-100 0"
                            class="AK7010_actuator" />

                            <!-- Coordinate axes -->
                        <geom type="capsule" fromto="0 0 0 0.1 0 0" size="0.003" rgba="1 0 0 1"  contype="0" conaffinity="0"/>
                        <geom type="capsule" fromto="0 0 0 0 0.1 0" size="0.003" rgba="0 1 0 1"  contype="0" conaffinity="0"/>
                        <geom type="capsule" fromto="0 0 0 0 0 0.1" size="0.003" rgba="0 0 1 1"  contype="0" conaffinity="0"/>

                        <site name="end_effector" pos="0 255.699E-03 6.00E-03" size="0.01" rgba="1 0 0 1" />

                            <!-- Coordinate axes -->
                            <geom type="capsule" fromto="0 255.699E-03 6.00E-03 0.1 255.699E-03 6.00E-03" size="0.003" rgba="1 0 0 1" contype="0" conaffinity="0"/>
                            <geom type="capsule" fromto="0 255.699E-03 6.00E-03 0 355.699E-03 6.00E-03" size="0.003" rgba="0 1 0 1" contype="0" conaffinity="0"/>
                            <geom type="capsule" fromto="0 255.699E-03 6.00E-03 0 255.699E-03 106.00E-03" size="0.003" rgba="0 0 1 1" contype="0" conaffinity="0"/>
                    </body>
                </body>
            </body>
        </body>

        <!-- ===================== 사람 (H≈1.60 m, 좌식) ===================== -->
        <!-- pos y=+0.12: 사람을 왼쪽으로 빼서 로봇이 몸통 오른쪽에 노출되게 함. -->
        <body name="human" pos="0 0.12 0.7" childclass="deco">
            <inertial pos="0 0.19 -0.25" mass="1" diaginertia="0.01 0.01 0.01"/>

            <!-- 목 / 머리 / 머리카락 -->
            <geom type="capsule" fromto="0 0.19 0.01  0 0.19 0.09" size="0.05" material="skin"/>
            <geom type="ellipsoid" pos="0.02 0.19 0.205" size="0.090 0.078 0.105" material="skin"/>
            <geom type="ellipsoid" pos="-0.01 0.19 0.24" size="0.097 0.084 0.082" material="hair"/>
            <!-- 얼굴 표정 (머리 앞면 +X). 눈/눈썹/코/미소 -->
            <geom type="sphere" pos="0.098 0.158 0.225" size="0.015"  material="eyewhite"/>
            <geom type="sphere" pos="0.098 0.222 0.225" size="0.015"  material="eyewhite"/>
            <geom type="sphere" pos="0.111 0.158 0.225" size="0.0075" material="eyedark"/>
            <geom type="sphere" pos="0.111 0.222 0.225" size="0.0075" material="eyedark"/>
            <geom type="capsule" fromto="0.098 0.140 0.252  0.098 0.176 0.254" size="0.006" material="eyedark"/>
            <geom type="capsule" fromto="0.098 0.204 0.254  0.098 0.240 0.252" size="0.006" material="eyedark"/>
            <geom type="ellipsoid" pos="0.114 0.19 0.196" size="0.018 0.013 0.022" material="skin"/>
            <!-- 입 (미소) -->
            <geom type="capsule" fromto="0.100 0.166 0.160  0.104 0.190 0.152" size="0.006" material="mouth"/>
            <geom type="capsule" fromto="0.104 0.190 0.152  0.100 0.214 0.160" size="0.006" material="mouth"/>

            <!-- 어깨 (deltoid) + 승모근 경사 -->
            <geom type="sphere"  pos="0 0.04 0"   size="0.055" material="shirt"/>
            <geom type="sphere"  pos="0 0.34 0"   size="0.055" material="shirt"/>
            <geom type="capsule" fromto="0 0.05 0.02  0 0.33 0.02" size="0.045" material="shirt"/>

            <!-- 몸통: capsule (가슴(shirt)+골반(pants)) -->
            <geom type="capsule" fromto="-0.01 0.19 -0.30  0.00 0.19 -0.05" size="0.125" material="shirt"/>
            <geom type="capsule" fromto="0.01 0.19 -0.42  0.01 0.19 -0.32"  size="0.120" material="pants"/>

            <!-- 왼팔 (오른팔 = 외골격이므로 생략) -->
            <geom type="capsule" fromto="0 0.34 -0.03  0.05 0.37 -0.30" size="0.048" material="shirt"/>
            <geom type="capsule" fromto="0.05 0.37 -0.30  0.30 0.31 -0.34" size="0.040" material="skin"/>
            <geom type="box" pos="0.36 0.30 -0.355" size="0.050 0.035 0.022" material="skin"/>

            <!-- 허벅지 -->
            <geom type="capsule" fromto="0.02 0.10 -0.46  0.48 0.11 -0.455" size="0.080" material="pants"/>
            <geom type="capsule" fromto="0.02 0.27 -0.46  0.48 0.27 -0.455" size="0.080" material="pants"/>
            <!-- 정강이 (무릎 → 발목) -->
            <geom type="capsule" fromto="0.48 0.11 -0.455  0.52 0.11 -0.91" size="0.055" material="pants"/>
            <geom type="capsule" fromto="0.48 0.27 -0.455  0.52 0.27 -0.91" size="0.055" material="pants"/>
            <!-- 발 (신발) -->
            <geom type="box" pos="0.60 0.11 -0.915" size="0.115 0.065 0.04" material="shoe"/>
            <geom type="box" pos="0.60 0.27 -0.915" size="0.115 0.065 0.04" material="shoe"/>
        </body>

        <!-- ===================== 의자 ===================== -->
        <body name="chair" pos="0 0.12 0.7" childclass="deco">
            <inertial pos="0.20 0.19 -0.6" mass="1" diaginertia="0.01 0.01 0.01"/>
            <!-- 좌판 -->
            <geom type="box" pos="0.125 0.19 -0.56" size="0.295 0.26 0.02" material="wood"/>
            <!-- 등받이 -->
            <geom type="box" pos="-0.17 0.19 -0.34" size="0.02 0.25 0.20" material="wood"/>
            <!-- 앞다리 2 -->
            <geom type="capsule" fromto="0.39 -0.05 -0.57  0.39 -0.05 -0.94" size="0.022" material="wood2"/>
            <geom type="capsule" fromto="0.39 0.43 -0.57  0.39 0.43 -0.94" size="0.022" material="wood2"/>
            <!-- 뒷기둥 2 = 다리 + 등받이 지지 -->
            <geom type="capsule" fromto="-0.17 -0.05 -0.94  -0.17 -0.05 -0.14" size="0.022" material="wood2"/>
            <geom type="capsule" fromto="-0.17 0.43 -0.94  -0.17 0.43 -0.14" size="0.022" material="wood2"/>
        </body>
    </worldbody>

    <!-- torque control -->
    <actuator>
        <motor name="act_shoulder_pitch" joint="shoulder_pitch" forcerange="-48 48"/>
        <motor name="act_shoulder_yaw" joint="shoulder_yaw" forcerange="-9 9"/>
        <motor name="act_elbow" joint="elbow" forcerange="-24.8 24.8"/>
    </actuator>

</mujoco>
